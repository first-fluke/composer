# ── Linear Issue Tracker ──────────────────────────────────
LINEAR_API_KEY=           # Linear Personal API Key (Settings → API)
LINEAR_TEAM_ID=           # Team identifier (e.g. ACR)
LINEAR_TEAM_UUID=         # Team UUID (for GraphQL queries)
LINEAR_WEBHOOK_SECRET=    # Linear webhook signing secret (Settings → API → Webhooks)
LINEAR_WORKFLOW_STATE_TODO=          # "Todo" state UUID
LINEAR_WORKFLOW_STATE_IN_PROGRESS=   # "In Progress" state UUID
LINEAR_WORKFLOW_STATE_DONE=          # "Done" state UUID
LINEAR_WORKFLOW_STATE_CANCELLED=     # "Cancelled" state UUID

# ── Symphony Orchestrator ─────────────────────────────────
WORKSPACE_ROOT=           # Agent workspace root absolute path (e.g. /home/user/workspaces)
LOG_LEVEL=info            # debug | info | warn | error

# ── Agent Selection ──────────────────────────────────────
AGENT_TYPE=claude         # claude | gemini | codex (default for issues without routing rules)
# MAX_PARALLEL=           # Max concurrent agents (auto-detected from hardware if not set)
SERVER_PORT=9741          # HTTP server port (default: 9741)
DELIVERY_MODE=merge       # merge (auto merge+push to main) | pr (agent creates PR for review)

# ── Multi-Repo Routing (optional) ──────────────────────
# Route issues to different git repos based on Linear labels.
# JSON array of rules. First matching label wins. Falls back to WORKSPACE_ROOT.
# Each rule: { "label": "<Linear label>", "workspaceRoot": "/abs/path/to/repo" }
# Optional per-rule overrides: "agentType", "deliveryMode"
#
# ROUTING_RULES='[{"label":"backend","workspaceRoot":"/home/user/repos/backend"},{"label":"frontend","workspaceRoot":"/home/user/repos/frontend","deliveryMode":"pr"}]'

# ── Score-Based Routing (optional) ────────────────────────
# Automatically score issue difficulty (ISO/IEC 14143 function points) and route to models.
# SCORING_MODEL=haiku       # LLM model for scoring analysis (cost-optimized)
# SCORE_ROUTING='{"easy":{"min":1,"max":3,"agent":"gemini"},"medium":{"min":4,"max":7,"agent":"codex"},"hard":{"min":8,"max":10,"agent":"claude"}}'

# Model override (optional — uses each CLI's default model if not set)
# CLAUDE_MODEL=sonnet           # sonnet (claude-sonnet-4-6) | opus (claude-opus-4-6) | haiku (claude-haiku-4-5)
# GEMINI_MODEL=gemini-2.0-flash # gemini-2.0-flash | gemini-2.5-pro etc.
# CODEX_MODEL=gpt-5.3-codex     # see ~/.codex/config.toml model value

# ── Observability (optional) ─────────────────────────────
LOG_FORMAT=json           # json | text
# OTEL_ENDPOINT=          # OpenTelemetry collector endpoint (optional)
