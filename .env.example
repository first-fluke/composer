# ── Linear 이슈 트래커 ──────────────────────────────────────
LINEAR_API_KEY=           # Linear Personal API Key (Settings → API)
LINEAR_TEAM_ID=           # 팀 식별자 (예: ACR)
LINEAR_TEAM_UUID=         # 팀 UUID (GraphQL 쿼리용)
LINEAR_WORKFLOW_STATE_IN_PROGRESS=   # "In Progress" 상태 UUID
LINEAR_WORKFLOW_STATE_DONE=          # "Done" 상태 UUID
LINEAR_WORKFLOW_STATE_CANCELLED=     # "Cancelled" 상태 UUID

# ── Symphony 오케스트레이터 ─────────────────────────────────
WORKSPACE_ROOT=./workspaces          # 에이전트 작업 공간 루트 경로
LOG_LEVEL=info                       # debug | info | warn | error
CODEX_SERVER_URL=http://localhost:3000   # Codex app-server 주소

# ── 관찰성 (선택) ───────────────────────────────────────────
LOG_FORMAT=json                      # json | text
# OTEL_ENDPOINT=                     # OpenTelemetry 수집 엔드포인트 (선택)
