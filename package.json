{
  "name": "agent-valley",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "av": "bun run --filter @agent-valley/cli av",
    "start": "bun run --cwd apps/dashboard dev",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "vitest run --config vitest.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
