{
  "name": "agent-valley",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "av": "bun apps/cli/src/index.ts",
    "start": "bun run --cwd apps/dashboard dev",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p apps/cli/tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": "biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6",
    "vitest": "^4.1.0"
  }
}
